# Security headers for static hosts that read a `_headers` file
# (Cloudflare Pages, Netlify). The key privacy line is `connect-src 'self'`:
# the browser is not permitted to send user data to any other origin.
#
# Note: 'unsafe-inline' for script/style is required by Next.js's static
# runtime (inline bootstrap + styles). 'wasm-unsafe-eval' lets the Hash
# Generator compile its hash-wasm WebAssembly modules in-browser. Neither
# weakens the egress guarantee — that is enforced by `connect-src 'self'`.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=()
